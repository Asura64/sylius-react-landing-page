---
import BaseLayout from '../../../layouts/BaseLayout.astro'
import '../../../App.scss'
import '../../../components/Footer/style.scss'
import '../../../components/ChatAvatar/style.scss'
import '../../../components/CourseChat/style.scss'
import '../../../components/CourseItem/Architecture/style.scss'
import '../../../components/CourseItem/Dump/style.scss'
import '../../../components/CourseItem/H2/style.scss'
import '../../../components/CourseItem/Img/style.scss'
import '../../../components/CourseItem/Info/style.scss'
import '../../../components/CourseItem/InlineRichText.scss'
import '../../../components/CourseItem/P/style.scss'
import '../../../components/CourseItem/Quiz/style.scss'
import '../../../components/CourseItem/Ul/style.scss'
import '../../../components/CourseItem/Yaml/style.scss'
import '../../Course/style.scss'
import { renderCourseItemHtml } from '../../../lib/courseItemHtml'
import { getCoursePageData } from '../../../lib/coursePage'
import { siteUrl } from '../../../lib/site'
import Header from '../../../components/Header.astro'
import ModuleIcon from '../../../components/ModuleIcon.astro'
import { courses } from '../../Course/_courses'
import { landingPage } from '../../LandingPage/_landingPage'

export function getStaticPaths() {
  return courses.map((course) => ({
    params: {
      courseSlug: course.slug,
    },
  }))
}

const { courseSlug } = Astro.params
const pageData = courseSlug ? getCoursePageData(courseSlug) : undefined

if (!pageData) {
  return Astro.redirect('/')
}

const {
  course,
  module,
  moduleCourses,
  previousCourse,
  nextCourse,
  nextPublicCourse,
  hasChat,
  themeClass,
  courseNavigation,
} = pageData

const { footer } = landingPage
const currentCourseIndex = moduleCourses.findIndex((item) => item.slug === course.slug)
---

<BaseLayout
  title={course.metaTitle || course.title}
  description={course.metaDescription || course.description}
  canonical={`${siteUrl}/cours/sylius/${course.slug}/`}
>
  <div class={`course-page ${themeClass}`}>
    <Header navigation={courseNavigation} brandHref="/#hero" showCta={false} />

    <main class="app">
      <nav
        class="course-page__timeline course-page__timeline--header"
        aria-label="Parcours du module"
        data-controller="course-timeline"
        data-course-timeline-current-slug-value={course.slug}
        data-course-timeline-courses-value={JSON.stringify(moduleCourses)}
      >
        <ol class="course-page__timeline-list">
          {moduleCourses.map((moduleCourse, index) => (
            <li
              class={`course-page__timeline-item${moduleCourse.slug === course.slug ? ' course-page__timeline-item--current' : ''}${index <= currentCourseIndex ? ' course-page__timeline-item--reached' : ''}`}
              data-course-slug={moduleCourse.slug}
            >
              <a class="course-page__timeline-link" href={`/cours/sylius/${moduleCourse.slug}/`}>
                <span class="course-page__timeline-marker">
                  <span>{index + 1}</span>
                  <span data-course-completed-check hidden aria-hidden="true">
                    ✓
                  </span>
                </span>
                <span class="course-page__timeline-label">{moduleCourse.title}</span>
              </a>
            </li>
          ))}
        </ol>
      </nav>

      <div class="course-page__shell">
        <section class="course-page__content" aria-label="Contenu du cours">
          <div class="course-page__eyebrow">
            <span class="course-page__eyebrow-icon" aria-hidden="true">
              <ModuleIcon name={module.icon} strokeWidth={2} />
            </span>
            <span>{module.title}</span>
          </div>
          <h1 class="course-page__title">{course.title}</h1>
          <p class="course-page__description">{course.description}</p>

          {course.private ? (
            <div class="course-page__locked">
              <p class="course-page__locked-title">Contenu réservé</p>
              <p class="course-page__locked-copy">
                Cette page de cours est un support pédagogique réservé à l'accompagnement
                personnalisé.
              </p>
              {course.skills.length ? (
                <div>
                  <p class="course-page__skills-title">Ce que ce cours vous apprend</p>
                  <ul class="course-page__skills-list">
                    {course.skills.map((skill) => (
                      <li class="course-page__skills-item">{skill}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
              <div class="course-page__locked-actions">
                {nextPublicCourse ? (
                  <a class="button button--tertiary" href={`/cours/sylius/${nextPublicCourse.slug}/`}>
                    Cours libre suivant
                  </a>
                ) : null}
                <a class="button button--primary" href="/#postuler">
                  Découvrir l'accompagnement
                </a>
              </div>
            </div>
          ) : !hasChat ? (
            <div class="course-page__locked">
              <p class="course-page__locked-title">Bientôt disponible gratuitement</p>
              <p class="course-page__locked-copy">
                Cette page est en cours de rédaction et sera bientôt disponible en accès libre.
              </p>
              {course.skills.length ? (
                <div>
                  <p class="course-page__skills-title">Ce que ce cours vous apprend</p>
                  <ul class="course-page__skills-list">
                    {course.skills.map((skill) => (
                      <li class="course-page__skills-item">{skill}</li>
                    ))}
                  </ul>
                </div>
              ) : null}
            </div>
          ) : (
            <>
              <div
                class="course-page__interactive"
                data-controller="course-chat"
                data-action="click->course-chat#handleClick change->course-chat#handleChange"
                data-course-chat-course-slug-value={course.slug}
                data-course-chat-next-course-value={JSON.stringify(nextCourse ?? null)}
                data-course-chat-previous-course-value={JSON.stringify(previousCourse ?? null)}
                data-course-chat-skills-value={JSON.stringify(course.skills)}
                data-course-chat-turns-value={JSON.stringify(course.chat)}
              >
                <div data-course-chat-target="mount"></div>
              </div>

              <div hidden aria-hidden="true">
                {course.chat.map((turn) =>
                  turn.content.map((item, itemIndex) => (
                    item.type === 'quiz' ? null : (
                      <template id={`course-item-template-${turn.id}-${itemIndex}`}>
                        <Fragment set:html={renderCourseItemHtml(item)} />
                      </template>
                    )
                  )),
                )}
              </div>
            </>
          )}
        </section>
      </div>
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__brand-group">
          <p class="site-footer__brand">{footer.brand}</p>
          <p class="site-footer__copy">{footer.copy}</p>
        </div>

        <nav class="site-footer__nav" aria-label="Liens secondaires">
          <button
            class="site-footer__link site-footer__link-button"
            type="button"
            onclick="window.CookieConsent && window.CookieConsent.showPreferences()"
          >
            🍪 Gérer les cookies
          </button>
          {footer.links.map((link) => (
            <a class="site-footer__link" href={link.href}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </footer>
  </div>
</BaseLayout>
