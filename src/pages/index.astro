---
import BaseLayout from '../layouts/BaseLayout.astro'
import '../App.scss'
import '../components/Footer/style.scss'
import '../components/SidebarNav/style.scss'
import '../components/JourneySection/style.scss'
import '../components/TimelineItem/style.scss'
import { getDefaultLandingStartHref } from '../lib/landingCta'
import { siteUrl } from '../lib/site'
import { landingPage } from './LandingPage/_landingPage'
import { courses, publicCourses, getCoursesByModuleId, getFirstCourseByModuleId } from './Course/_courses'
import ModuleIcon from '../components/ModuleIcon.astro'
import Header from '../components/Header.astro'
import HeroSection from '../components/HeroSection.astro'
import FeatureGrid from '../components/FeatureGrid.astro'

const { navigation, hero, modules, featureGrid, footer } = landingPage
const startHref = getDefaultLandingStartHref(publicCourses, navigation.cta.href)

const landingNavigation = {
  ...navigation,
  cta: {
    ...navigation.cta,
    href: startHref,
  },
}

const landingHero = {
  ...hero,
  primaryAction: {
    ...hero.primaryAction,
    href: startHref,
  },
}

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Patxi Iparaguirre',
      description: 'Formateur, mentor et lead developer spécialisé sur Sylius 2.',
      sameAs: [
        'https://docs.sylius.com',
        'https://sylius.com/slack',
        'https://demo.sylius.com',
      ],
    },
    {
      '@type': 'Course',
      name: 'Formation Sylius 2',
      description:
        'Formation Sylius 2 orientée installation, configuration métier de la boutique, personnalisation, workflow, qualité et accompagnement sur mesure.',
      provider: {
        '@type': 'Organization',
        name: 'Patxi Iparaguirre',
      },
      educationalLevel: 'Advanced',
      teaches: [
        'Installation de Sylius 2',
        'Configuration de la boutique Sylius',
        'Fixtures YAML',
        'ResourceBundle',
        'Grilles admin et front',
        'Twig Hooks',
        'Symfony UX Live Components',
        'Workflow',
        'Qualité de code',
      ],
    },
  ],
}
---

<BaseLayout
  title="Formation Sylius 2 pour les devs : architecture, personnalisation et mentorat expert"
  description={hero.description}
  canonical={siteUrl}
  schema={schema}
>
  <Header navigation={landingNavigation} />

  <main
    class="app"
    data-controller="landing-page"
    data-action="click->landing-page#handleClick"
    data-landing-page-courses-value={JSON.stringify(courses)}
    data-landing-page-public-courses-value={JSON.stringify(publicCourses)}
    data-landing-page-fallback-href-value={navigation.cta.href}
  >
    <div class="app__layout">
      <aside class="sidebar">
        <div class="sidebar__panel">
          <p class="sidebar__title">Modules de formation</p>
          <nav class="sidebar__nav" aria-label="Modules de formation">
            {modules.map((module, index) => (
              <a class={`sidebar__link${index === 0 ? ' sidebar__link--current' : ''}`} href={`#${module.slug}`}>
                <ModuleIcon className="sidebar__icon" name={module.icon} strokeWidth={2} />
                <span>{module.title}</span>
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <div class="app__content">
        <HeroSection hero={landingHero} />

        <section id="modules" class="journey">
          <div class="section-heading section-heading--centered">
            <p class="section-heading__kicker">Le Parcours</p>
            <h2 class="section-heading__title">Le parcours d'apprentissage</h2>
            <p class="section-heading__description">
              Un programme de formation Sylius 2 structuré pour passer de l'installation à la
              mise en production d'une boutique e-commerce personnalisée.
            </p>
          </div>

          <div class="timeline" aria-label="Programme de formation">
            <div class="timeline__line" aria-hidden="true">
              <div
                class="timeline__line-fill"
                style="height: 0%; background: linear-gradient(180deg, #1100bc, #7547ab);"
              ></div>
            </div>

            {modules.map((module, index) => {
              const moduleCourses = getCoursesByModuleId(module.id)
              const href = getFirstCourseByModuleId(module.id)?.slug
                ? `/cours/sylius/${getFirstCourseByModuleId(module.id)?.slug}/`
                : undefined

              return (
                <article
                  id={module.slug}
                  class={`timeline__item timeline__item--${module.layout} timeline__item--${module.theme}${index === 0 ? ' timeline__item--reached timeline__item--current' : ''}`}
                  data-theme={module.theme}
                >
                  {moduleCourses.length ? (
                    <div class="timeline__courses-shell timeline__courses-shell--desktop">
                      <div class="timeline__courses">
                        <ul class="timeline__courses-list">
                          {moduleCourses.map((course) => (
                            <li class="timeline__courses-item" data-course-slug={course.slug}>
                              <a class="timeline__courses-link" href={`/cours/sylius/${course.slug}/`}>
                                <span class="timeline__courses-name">{course.title}</span>
                                <span
                                  class="timeline__courses-check"
                                  aria-label="Cours terminé"
                                  hidden
                                >
                                  ✓
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  ) : null}

                  <div class="timeline__marker">{index + 1}</div>

                  {href ? (
                    <a class="timeline__card timeline__card--interactive" href={href}>
                      <div class="timeline__heading">
                        <div class="timeline__icon" aria-hidden="true">
                          <ModuleIcon className="timeline__icon-svg" name={module.icon} strokeWidth={2} />
                        </div>
                        <h3 class="timeline__title">{module.title}</h3>
                      </div>
                      <p class="timeline__description">{module.description}</p>
                      <div class={`timeline__art timeline__art--${module.art}`} aria-hidden="true"></div>
                    </a>
                  ) : (
                    <div class="timeline__card">
                      <div class="timeline__heading">
                        <div class="timeline__icon" aria-hidden="true">
                          <ModuleIcon className="timeline__icon-svg" name={module.icon} strokeWidth={2} />
                        </div>
                        <h3 class="timeline__title">{module.title}</h3>
                      </div>
                      <p class="timeline__description">{module.description}</p>
                      <div class={`timeline__art timeline__art--${module.art}`} aria-hidden="true"></div>
                    </div>
                  )}

                  {moduleCourses.length ? (
                    <details class="timeline__courses-shell timeline__courses-shell--mobile">
                      <summary class="timeline__courses-summary">Voir les cours disponibles</summary>
                      <div class="timeline__courses timeline__courses--mobile">
                        <ul class="timeline__courses-list">
                          {moduleCourses.map((course) => (
                            <li class="timeline__courses-item" data-course-slug={course.slug}>
                              <a class="timeline__courses-link" href={`/cours/sylius/${course.slug}/`}>
                                <span class="timeline__courses-name">{course.title}</span>
                                <span
                                  class="timeline__courses-check"
                                  aria-label="Cours terminé"
                                  hidden
                                >
                                  ✓
                                </span>
                              </a>
                            </li>
                          ))}
                        </ul>
                      </div>
                    </details>
                  ) : null}
                </article>
              )
            })}
          </div>
        </section>

        <FeatureGrid featureGrid={featureGrid} />
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <div class="site-footer__brand-group">
        <p class="site-footer__brand">{footer.brand}</p>
        <p class="site-footer__copy">{footer.copy}</p>
      </div>

      <nav class="site-footer__nav" aria-label="Liens secondaires">
        <button
          class="site-footer__link site-footer__link-button"
          type="button"
          onclick="window.CookieConsent && window.CookieConsent.showPreferences()"
        >
          🍪 Gérer les cookies
        </button>
        {footer.links.map((link) => (
          <a class="site-footer__link" href={link.href}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </footer>

</BaseLayout>
