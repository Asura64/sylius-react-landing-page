---
import type { FeatureGridContent } from '../types/content'
import { renderFeatureIconSvg } from '../lib/iconSvg'
import './FeatureGrid/style.scss'

type Props = {
  featureGrid: FeatureGridContent
}

const { featureGrid } = Astro.props
---

<section id="postuler" class="feature-grid">
  <article class="feature-grid__panel">
    <div class="feature-grid__intro">
      <p class="feature-grid__kicker">{featureGrid.kicker}</p>
      <h2 class="feature-grid__title">{featureGrid.title}</h2>
      <p class="feature-grid__copy">{featureGrid.description}</p>

      <div class="feature-grid__actions">
        {featureGrid.actions.map((action) => (
          <a
            class={`button ${action.variant === 'light' ? 'button--light' : 'button--outline-light'}`}
            href={action.href}
            target={action.href.startsWith('http') ? '_blank' : undefined}
            rel={action.href.startsWith('http') ? 'noreferrer' : undefined}
          >
            {action.label}
          </a>
        ))}
      </div>
    </div>

    <div class="feature-grid__highlights">
      {featureGrid.highlights.map((item, index) => (
        <article
          class={`feature-grid__highlight feature-grid__highlight--${item.tone}${index === featureGrid.highlights.length - 1 ? ' feature-grid__highlight--wide' : ''}`}
        >
          <div class="feature-grid__highlight-heading">
            <div class="feature-grid__highlight-icon" aria-hidden="true">
              <Fragment
                set:html={renderFeatureIconSvg(item.title, {
                  className: 'feature-grid__highlight-icon-svg',
                  strokeWidth: 2,
                })}
              />
            </div>
            <h3 class="feature-grid__highlight-title">{item.title}</h3>
          </div>
          <p class="feature-grid__highlight-copy">{item.description}</p>
        </article>
      ))}
    </div>
  </article>
</section>
