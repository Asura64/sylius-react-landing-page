{
  "name": "patxi",
  "private": true,
  "version": "0.0.0",
  "homepage": "https://patxi.iparaguirre.fr",
  "type": "module",
  "scripts": {
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-prerender.tsx --outDir dist-ssr",
    "build:prerender": "npm run build:client && npm run build:server && node ./scripts/prerender.mjs",
    "deploy:prerender": "npm run build:prerender && gh-pages -d prerender-dist -b prerender",
    "dev": "vite --host",
    "build": "npm run build:client",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "sass-embedded": "^1.93.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.1"
  }
}
